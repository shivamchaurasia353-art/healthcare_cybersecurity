NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=healthcare_cybersec
DB_USER=hcs_admin
DB_PASSWORD=change_this_strong_password

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_for_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_also_very_long
JWT_REFRESH_EXPIRES_IN=7d

# MFA (TOTP)
MFA_APP_NAME=HealthSecure

# Consent Token
CONSENT_TOKEN_SECRET=change_this_consent_token_secret
CONSENT_TOKEN_EXPIRES_IN=24h

# Health ID
HEALTH_ID_PREFIX=ABHA

# Audit
AUDIT_LOG_DIR=./logs/audit
APP_LOG_DIR=./logs/app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Encryption
ENCRYPTION_KEY=change_this_32_char_aes_key_here_
ENCRYPTION_IV=change_this_16chr
